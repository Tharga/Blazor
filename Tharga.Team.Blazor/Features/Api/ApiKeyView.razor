@using Microsoft.Extensions.Options
@using Microsoft.JSInterop
@using Tharga.Team
@using Tharga.Team.Blazor.Features.Team
@using Microsoft.AspNetCore.Components.Authorization
@inject ITeamStateService TeamStateService
@inject IApiKeyManagementService ApiKeyManagementService
@inject AuthenticationStateProvider AuthStateProvider
@inject IOptions<ApiKeyOptions> ApiKeyOptionsAccessor
@inject IScopeRegistry ScopeRegistry
@inject IJSRuntime Js
@inject DialogService DialogService
@inject NotificationService NotificationService

@if (!_hasAccess)
{
    <RadzenText>Access denied. You need the API key management permission to view this page.</RadzenText>
}
else if (_selectedTeam == null)
{
    <RadzenText>No team selected.</RadzenText>
}
else if (_keys == null)
{
    <Loading />
}
else
{
    <RadzenDataGrid Data="@_keys" TItem="ApiKeyModel">
        <Columns>
            <RadzenDataGridColumn Title="Name" Property="@nameof(ApiKeyModel.Name)" Width="180px" />
            <RadzenDataGridColumn Title="Key" Property="@nameof(ApiKeyModel.VisibleKey)" />
            @if (_options.AdvancedMode)
            {
                <RadzenDataGridColumn Title="Access Level" Width="130px">
                    <Template>
                        @context.AccessLevel
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn Title="Roles" Width="150px">
                    <Template>
                        @string.Join(", ", context?.Roles ?? Array.Empty<string>())
                    </Template>
                </RadzenDataGridColumn>
            }
            <RadzenDataGridColumn Title="Expiry" Width="130px">
                <Template>
                    @if (context.ExpiryDate.HasValue)
                    {
                        <span style="@(context.IsExpired ? "color: red" : "")">
                            <DateTimeView Date="@context.ExpiryDate" />
                        </span>
                    }
                    else
                    {
                        <RadzenText>No expiry</RadzenText>
                    }
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn Title="" Width="40px">
                <Template>
                    <span title="@GetKeyScopesText(context)">
                        <RadzenIcon Icon="info" Style="cursor: help;" />
                    </span>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn Width="@(_options.AdvancedMode ? "220px" : "180px")">
                <Template>
                    <RadzenButton Icon="visibility" Click="@(_ => context.VisibleKey = context.ApiKey)" Visible="@(!string.IsNullOrEmpty(context.ApiKey) && context.VisibleKey == _apiKeyMask)" />
                    <RadzenButton Icon="visibility_off" Click="@(_ => context.VisibleKey = _apiKeyMask)" Visible="@(!string.IsNullOrEmpty(context.ApiKey) && context.VisibleKey != _apiKeyMask)" />
                    <RadzenButton Icon="content_copy" Click="@(_ => CopyToClipboard(context))" Visible="@(IsKeyVisible(context))" />
                    <RadzenButton Icon="lock" Click="@(_ => LockKeyAsync(context))" Visible="@(!string.IsNullOrEmpty(context.ApiKey))" />
                    <RadzenButton Icon="refresh" Click="@(_ => RefreshAsync(context))" />
                    <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Flat" Click="@(_ => DeleteAsync(context))" Visible="@(_options.AdvancedMode)" />
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>

    @if (_options.AdvancedMode)
    {
        <RadzenCard class="rz-mt-4">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.End" Gap="1rem">
                <RadzenStack Gap="0.25rem">
                    <RadzenLabel Text="Name" />
                    <RadzenTextBox Value="@_newName" @oninput="@(e => _newName = e.Value?.ToString() ?? "")" Placeholder="Key name" />
                </RadzenStack>
                <RadzenStack Gap="0.25rem">
                    <RadzenLabel Text="Access Level" />
                    <RadzenDropDown TValue="AccessLevel" @bind-Value="_newAccessLevel" Data="@_accessLevels" />
                </RadzenStack>
                <RadzenStack Gap="0.25rem">
                    <RadzenLabel Text="Expiry Date" />
                    <RadzenDatePicker @bind-Value="_newExpiryDate" DateFormat="yyyy-MM-dd"
                                      AllowClear="@(!_options.MaxExpiryDays.HasValue)"
                                      Min="@DateTime.UtcNow.Date"
                                      Max="@(_options.MaxExpiryDays.HasValue ? DateTime.UtcNow.AddDays(_options.MaxExpiryDays.Value).Date : DateTime.MaxValue)" />
                </RadzenStack>
                <RadzenButton Text="Create" Icon="add" Click="@CreateAsync"
                              Disabled="@string.IsNullOrWhiteSpace(_newName)" />
            </RadzenStack>
        </RadzenCard>
    }
}

@code {
    private bool _hasAccess;
    private ITeam _selectedTeam;
    private ApiKeyModel[] _keys;
    private ApiKeyOptions _options;
    private readonly string _apiKeyMask = "**********";
    private readonly AccessLevel[] _accessLevels = Enum.GetValues<AccessLevel>().Where(x => x != AccessLevel.Owner).ToArray();

    private string _newName = "";
    private AccessLevel _newAccessLevel = AccessLevel.User;
    private DateTime? _newExpiryDate;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        _hasAccess = user.HasClaim(TeamClaimTypes.Scope, ApiKeyScopes.Manage);
        if (!_hasAccess) { await base.OnInitializedAsync(); return; }

        _options = ApiKeyOptionsAccessor.Value;
        _newExpiryDate = _options.MaxExpiryDays.HasValue
            ? DateTime.UtcNow.AddDays(_options.MaxExpiryDays.Value).Date
            : null;
        _selectedTeam = await TeamStateService.GetSelectedTeamAsync();
        await ReloadData();
        await base.OnInitializedAsync();
    }

    private async Task ReloadData()
    {
        if (_selectedTeam?.Key == null) return;

        var keys = await ApiKeyManagementService.GetKeysAsync(_selectedTeam.Key).ToArrayAsync();
        _keys = keys
            .Select(x =>
            {
                return new ApiKeyModel
                {
                    Key = x.Key,
                    Name = x.Name,
                    ApiKey = x.ApiKey,
                    VisibleKey = _apiKeyMask,
                    AccessLevel = x.AccessLevel ?? AccessLevel.Administrator,
                    Roles = x.Roles,
                    ScopeOverrides = x.ScopeOverrides,
                    ExpiryDate = x.ExpiryDate,
                    CreatedAt = x.CreatedAt,
                };
            }).ToArray();

        StateHasChanged();
    }

    private async Task CreateAsync()
    {
        try
        {
            var created = await ApiKeyManagementService.CreateKeyAsync(_selectedTeam.Key, _newName, _newAccessLevel, null, _newExpiryDate);
            _newName = "";
            _newAccessLevel = AccessLevel.User;
            _newExpiryDate = _options.MaxExpiryDays.HasValue
                ? DateTime.UtcNow.AddDays(_options.MaxExpiryDays.Value).Date
                : null;
            await ReloadData();
            ShowKeyOnce(created);
            NotificationService.Notify(NotificationSeverity.Success, "API key created");
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Failed to create key", ex.Message);
        }
    }

    private async Task RefreshAsync(ApiKeyModel context)
    {
        var result = await DialogService.Confirm($"The {context.Name} key will be regenerated.", "Confirm regenerate API key");
        if (result != true) return;

        var refreshed = await ApiKeyManagementService.RefreshKeyAsync(_selectedTeam.Key, context.Key);
        await ReloadData();
        ShowKeyOnce(refreshed);
    }

    private void ShowKeyOnce(IApiKey key)
    {
        if (key == null || string.IsNullOrEmpty(key.ApiKey)) return;
        var model = _keys?.FirstOrDefault(k => k.Key == key.Key);
        if (model != null)
        {
            model.VisibleKey = key.ApiKey;
        }
        StateHasChanged();
    }

    private string GetKeyScopesText(ApiKeyModel context)
    {
        var accessLevelScopes = ScopeRegistry.GetScopesForAccessLevel(context.AccessLevel);
        var overrides = context.ScopeOverrides ?? Array.Empty<string>();
        var allScopes = ScopeRegistry.GetEffectiveScopes(context.AccessLevel, context.Roles, context.ScopeOverrides);

        var lines = new List<string>();
        foreach (var scope in allScopes)
        {
            var origin = overrides.Contains(scope) ? "override"
                : accessLevelScopes.Contains(scope) ? "access level"
                : "role";
            lines.Add($"{scope} ({origin})");
        }
        return string.Join("\n", lines);
    }

    private bool IsKeyVisible(ApiKeyModel context)
    {
        return !string.IsNullOrEmpty(context.VisibleKey) && context.VisibleKey != _apiKeyMask;
    }

    private async Task CopyToClipboard(ApiKeyModel context)
    {
        var keyToCopy = IsKeyVisible(context) ? context.VisibleKey : context.ApiKey;
        await Js.InvokeVoidAsync("clipboard.copyText", keyToCopy);
        NotificationService.Notify(new NotificationMessage
        {
            Summary = $"The {context.Name} key has been copied to the clipboard."
        });
    }

    private async Task LockKeyAsync(ApiKeyModel context)
    {
        var result = await DialogService.Confirm($"The {context.Name} key will be locked. After that, it cannot be retrieved.", "Confirm lock API key");
        if (result != true) return;

        await ApiKeyManagementService.LockKeyAsync(_selectedTeam.Key, context.Key);
        await ReloadData();
    }

    private async Task DeleteAsync(ApiKeyModel context)
    {
        var result = await DialogService.Confirm($"Delete API key '{context.Name}'? This cannot be undone.", "Confirm delete");
        if (result != true) return;

        try
        {
            await ApiKeyManagementService.DeleteKeyAsync(_selectedTeam.Key, context.Key);
            await ReloadData();
            NotificationService.Notify(NotificationSeverity.Success, "API key deleted");
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Failed to delete key", ex.Message);
        }
    }
}
